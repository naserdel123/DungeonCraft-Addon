{
    "format_version": "1.20.0",
    "minecraft:item": {
        "description": {
            "identifier": "dungeoncraft:dungeon_key",
            "category": "items"
        },
        "components": {
            "minecraft:max_stack_size": 16,
            "minecraft:icon": {
                "texture": "dungeon_key"
            },
            "minecraft:creative_category": {
                "parent": "itemGroup.name.items"
            },
            "minecraft:hover_text_color": "red",
            "minecraft:display_name": {
                "value": "§4Dungeon Key§r"
            },
            "minecraft:foil": true,
            "minecraft:on_use_on": {
                "on_use_on": {
                    "event": "dungeoncraft:unlock",
                    "target": "block"
                }
            }
        },
        "events": {
            "dungeoncraft:unlock": {
                "run_command": {
                    "command": [
                        "setblock ~ ~ ~ air destroy",
                        "particle minecraft:large_explosion ~ ~ ~",
                        "playsound random.anvil_land @a ~ ~ ~ 1.0",
                        "clear @s dungeoncraft:dungeon_key 0 1"
                    ]
                }
            }
        }
    }
}
